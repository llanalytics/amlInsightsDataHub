{
  "required": ["customer_key", "name", "segment"],
  "properties": {
    "customer_key": {
      "type": "string",
      "maxLength": 100,
      "dq": {
        "not_null": true,
        "regex": "^CUST-[0-9]{3,}$"
      }
    },
    "name": {
      "type": "string",
      "maxLength": 120,
      "dq": {
        "not_null": true
      }
    },
    "segment": {
      "type": "string",
      "maxLength": 80,
      "dq": {
        "not_null": true,
        "lookup_name": "Customer_Segment"
      }
    }
  },
  "additionalProperties": false
}
