  "properties": {
    "currency_code": {
      "type": "string",
      "maxLength": 20,
      "dq": {
        "not_null": true,
        "regex": "^[A-Z]{3}$"
      }
    },
    "currency_name": {
      "type": "string",
      "maxLength": 120,
      "dq": {
        "not_null": true
      }
    },
    "associated_countries": {
      "type": "string",
      "maxLength": 4000,
      "dq": {
        "not_null": true
      }
    }
  },
  "additionalProperties": false
}
